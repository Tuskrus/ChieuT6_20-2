{
  "info": {
    "_postman_id": "inventory-management-system",
    "name": "Inventory Management System",
    "description": "Complete API collection for testing Inventory Management endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "12345678"
  },
  "item": [
    {
      "name": "Get All Inventories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories"]
        },
        "description": "Retrieve all inventories with product details"
      },
      "response": []
    },
    {
      "name": "Get Inventory by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories/:inventoryId",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories", ":inventoryId"],
          "variable": [
            {
              "key": "inventoryId",
              "value": "PASTE_INVENTORY_ID_HERE"
            }
          ]
        },
        "description": "Get a specific inventory by ID with full product details"
      },
      "response": []
    },
    {
      "name": "Add Stock",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"PASTE_PRODUCT_ID_HERE\",\n  \"quantity\": 50\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories/add-stock",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories", "add-stock"]
        },
        "description": "Increase the stock for a product"
      },
      "response": []
    },
    {
      "name": "Remove Stock",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"PASTE_PRODUCT_ID_HERE\",\n  \"quantity\": 10\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories/remove-stock",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories", "remove-stock"]
        },
        "description": "Decrease the stock for a product"
      },
      "response": []
    },
    {
      "name": "Reserve Stock",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"PASTE_PRODUCT_ID_HERE\",\n  \"quantity\": 20\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories/reservation",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories", "reservation"]
        },
        "description": "Reserve stock (decreases stock, increases reserved)"
      },
      "response": []
    },
    {
      "name": "Mark as Sold",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product\": \"PASTE_PRODUCT_ID_HERE\",\n  \"quantity\": 15\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/inventories/sold",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "inventories", "sold"]
        },
        "description": "Mark reserved items as sold (decreases reserved, increases soldCount)"
      },
      "response": []
    },
    {
      "name": "Create Product (Auto Creates Inventory)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"New Product\",\n  \"price\": 99.99,\n  \"description\": \"A new product description\",\n  \"categoryId\": \"PASTE_CATEGORY_ID_HERE\",\n  \"images\": [\"https://example.com/image.jpg\"]\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "products"]
        },
        "description": "Create a new product. This automatically creates a corresponding inventory record."
      },
      "response": []
    }
  ]
}
